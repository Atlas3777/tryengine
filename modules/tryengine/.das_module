options gen2
require daslib/fio

[export]
def initialize(project_path : string) {
    if (das_is_dll_build()) {
        // Загружаем скомпилированный модуль. Имя класса должно строго совпадать с C++ (Module_Renderer)
        register_dynamic_module("{project_path}/tryengine.shared_module", "Module_Renderer")
    }
}